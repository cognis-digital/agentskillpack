# Keep line endings deterministic across platforms.
# Shell scripts and JSON assets must stay LF so they run/compare identically on
# Linux/macOS CI even when checked out on Windows.
* text=auto eol=lf
*.sh text eol=lf
*.ps1 text eol=crlf
*.json text eol=lf
*.rs text eol=lf
*.md text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
